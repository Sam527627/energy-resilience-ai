# ════════════════════════════════════════════
# EnergyShield AI × Foresight Live
# Environment Configuration — Copy to .env
# ════════════════════════════════════════════

# ── CORE (Required) ──────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here       # console.anthropic.com
DEMO_MODE=false                                      # true = use simulated data, no API calls

# ── NEWS & GEOPOLITICAL ──────────────────────
NEWS_API_KEY=your_newsapi_key_here                   # newsapi.org — free tier 100req/day

# ── AIS / VESSEL TRACKING ────────────────────
# Use any one (or multiple) of these:
AIS_API_KEY=your_datalastic_key_here                 # datalastic.com — most affordable
MARINETRAFFIC_KEY=your_marinetraffic_key_here        # marinetraffic.com — industry standard
VESSELFINDER_KEY=your_vesselfinder_key_here          # vesselfinder.com
MYSHIPTRACKING_KEY=your_myshiptracking_key_here      # myshiptracking.com
SPIRE_KEY=your_spire_key_here                        # spire.com — satellite AIS
EXACTEARTH_KEY=your_exactearth_key_here              # exactearth.com — satellite AIS

# ── COMMODITY / MARKET DATA ──────────────────
EIA_API_KEY=your_eia_key_here                        # eia.gov — FREE US government API
ALPHA_VANTAGE_KEY=your_alphavantage_key_here         # alphavantage.co — free tier
FRED_API_KEY=your_fred_key_here                      # fred.stlouisfed.org — FREE
QUANDL_KEY=your_quandl_key_here                      # quandl.com — commodity history

# ── WEATHER / METOCEAN ───────────────────────
OPENWEATHER_KEY=your_openweather_key_here            # openweathermap.org — free tier
STORMGLASS_KEY=your_stormglass_key_here              # stormglass.io — marine weather
# NOTE: Open-Meteo Marine API is FREE with no key required (used automatically)

# ── COMPLIANCE / SANCTIONS ───────────────────
OFAC_API_KEY=your_ofac_key_here                      # optional — OFAC SDN JSON is free
LSEG_KEY=your_lseg_key_here                          # lseg.com — World-Check (enterprise)
# NOTE: OFAC SDN, EU, UN lists are publicly available without keys

# ── MAPPING ──────────────────────────────────
MAPBOX_TOKEN=your_mapbox_token_here                  # mapbox.com — free tier 50K loads/mo

# ── APP SETTINGS ─────────────────────────────
APP_TITLE=EnergyShield AI × Foresight Live
CACHE_TTL_SECS=300
